{
  "name": "andro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:content && vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "validate:content": "vitest run src/content/registry.spec.ts",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "@tailwindcss/vite": "^4.3.3",
    "pinia": "^4.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "tailwindcss": "^4.3.3",
    "vue": "^3.5.39",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.5"
  },
  "allowScripts": {
    "vue-demi@0.14.10": true
  }
}
